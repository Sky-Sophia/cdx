<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.javawebdemo.mapper.OrderItemMapper">
    <insert id="insertBatch">
        INSERT INTO order_items (order_id, show_seat_id, seat_label, price)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (#{item.orderId}, #{item.showSeatId}, #{item.seatLabel}, #{item.price})
        </foreach>
    </insert>

    <select id="findByOrderId" resultType="OrderItem">
        SELECT * FROM order_items WHERE order_id = #{orderId}
    </select>
</mapper>
